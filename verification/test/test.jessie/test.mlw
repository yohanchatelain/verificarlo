val uint8_of_integer_
 (x:int) : uint8
  requires { ((Int.(<=) (0) x) /\ (Int.(<=) x (255))) }
   ensures { ((integer_of_uint8 result) = x) }

let test1_ensures_default "W:diverges:N" "expl:Function test1, default behavior"
 #"/home/yohan/Documents/verificarlo/verification/test/test.c" 4 7 12#=
 fun (tt : ()) ->
  requires { (#"/home/yohan/Documents/verificarlo/verification/test/test.jessie/" 0 0 0#
             true)  }
  ensures { (#"/home/yohan/Documents/verificarlo/verification/test/test.c" 3 12 26#
            ((Double.value result) = 7.0)) } 
  ('Init: 
  (let return = ref (any_double ()) in
  try
   begin
     (let __retres = ref (any_double ()) in
     begin
       (let _jessie_5 =
       (__retres := ("expl:floating-point overflow"
                    #"/home/yohan/Documents/verificarlo/verification/test/test.c" 5 9 18#
                    (mul_double_safe Rounding.NearestTiesToEven (double_of_real_exact 2.0) 
                     (double_of_real_safe Rounding.NearestTiesToEven 3.5)))) in
       ()); (return := !__retres); (raise Return) end); absurd  end with
   Return -> !return end)) 

